TZ=Asia/Jakarta

BOT_NAME=IRIS Organizer
BOT_OWNER_TITLE=Bapak

# WhatsApp session
WHATSAPP_SESSION_DIR=./runtime/session
WHATSAPP_ALLOWED_NUMBERS=6281234567890
WHATSAPP_BLOCKED_NUMBERS=

# Local storage on the remote machine
STORAGE_ROOT=./runtime/storage
STATE_ROOT=./runtime/state
LOG_ROOT=./runtime/logs
DEFAULT_CATEGORY=umum

# Local bot API
BOT_HTTP_HOST=0.0.0.0
BOT_HTTP_PORT=8030
BOT_API_TOKEN=replace-with-local-bot-token

# Remote IRIS brain
IRIS_BASE_URL=http://127.0.0.1:3000
IRIS_DECIDE_PATH=/api/internal/organizer/decide
IRIS_API_TOKEN=replace-with-iris-internal-token
IRIS_TIMEOUT_MS=40000
IRIS_FALLBACK_ENABLED=true
