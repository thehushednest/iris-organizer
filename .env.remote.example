TZ=Asia/Jakarta

BOT_NAME=IRIS Organizer - Nama Anda
BOT_OWNER_TITLE=Bapak

# Nomor yang diizinkan memakai bot ini
WHATSAPP_ALLOWED_NUMBERS=6281234567890

# Session dan data lokal di mesin remote
WHATSAPP_SESSION_DIR=./runtime/session
STORAGE_ROOT=./runtime/storage
STATE_ROOT=./runtime/state
LOG_ROOT=./runtime/logs
DEFAULT_CATEGORY=umum

# API lokal bot
BOT_HTTP_HOST=0.0.0.0
BOT_HTTP_PORT=8030
BOT_API_TOKEN=ganti_dengan_token_bot_lokal

# IP / domain server IRIS utama
IRIS_BASE_URL=http://192.168.1.10:3000
IRIS_DECIDE_PATH=/api/internal/organizer/decide
IRIS_API_TOKEN=ganti_dengan_internal_api_token_iris
IRIS_TIMEOUT_MS=40000
IRIS_FALLBACK_ENABLED=true
